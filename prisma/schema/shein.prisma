model SheinBatch {
  id                        String           @id @default(cuid())
  batchName                 String
  sourceCountry             String           @default("Malaysia")
  currency                  String           @default("MYR")
  customerRmRate            Decimal          @default(33) @db.Decimal(14, 4)
  bankRate                  Decimal?         @db.Decimal(14, 4)
  customerWeightRatePerGram Decimal          @default(1.25) @db.Decimal(14, 4)
  actualCargoRatePerGram    Decimal          @default(0.98) @db.Decimal(14, 4)
  orderDate                 DateTime?
  sheinOrderNumbers         String?
  sheinTrackingNumber       String?
  status                    SheinBatchStatus @default(CONFIRMED)
  notes                     String?
  items                     SheinBatchItem[]
  createdAt                 DateTime         @default(now())
  updatedAt                 DateTime         @updatedAt

  @@index([status])
  @@index([orderDate])
  @@map("shein_batches")
}

model SheinBatchItem {
  id                         String                @id @default(cuid())
  batchId                    String
  batch                      SheinBatch            @relation(fields: [batchId], references: [id], onDelete: Cascade)
  customerName               String
  phone                      String
  address                    String?
  productName                String
  sheinLink                  String?
  imageUrl                   String?
  screenshotUrl              String?
  size                       String?
  color                      String?
  quantity                   Int                   @default(1)
  customerQuotedPriceBdt     Decimal               @db.Decimal(14, 4)
  advanceReceivedBdt         Decimal               @default(0) @db.Decimal(14, 4)
  actualSheinPriceRm         Decimal?              @db.Decimal(14, 4)
  bankRateSnapshot           Decimal?              @db.Decimal(14, 4)
  actualItemCostBdt          Decimal?              @db.Decimal(14, 4)
  actualWeightGram           Int?
  customerWeightRateSnapshot Decimal               @default(1.25) @db.Decimal(14, 4)
  customerWeightChargeBdt    Decimal?              @db.Decimal(14, 4)
  actualCargoRateSnapshot    Decimal               @default(0.98) @db.Decimal(14, 4)
  actualCargoCostBdt         Decimal?              @db.Decimal(14, 4)
  totalCustomerPayableBdt    Decimal?              @db.Decimal(14, 4)
  totalActualCostBdt         Decimal?              @db.Decimal(14, 4)
  profitBdt                  Decimal?              @db.Decimal(14, 4)
  remainingDueBdt            Decimal?              @db.Decimal(14, 4)
  status                     SheinBatchItemStatus  @default(CONFIRMED)
  movedToOrderId             Int?
  movedToOrderItemId         Int?                  @unique
  movedAt                    DateTime?
  movedToOrder               Order?                @relation("SheinBatchItemMovedToOrder", fields: [movedToOrderId], references: [id], onDelete: SetNull)
  movedToOrderItem           OrderItem?            @relation("SheinBatchItemMovedToOrderItem", fields: [movedToOrderItemId], references: [id], onDelete: SetNull)
  orderItems                 OrderItem[]           @relation("SheinOrderItemSource")
  createdAt                  DateTime              @default(now())
  updatedAt                  DateTime              @updatedAt

  @@index([batchId])
  @@index([phone])
  @@index([customerName])
  @@index([status])
  @@index([movedToOrderId])
  @@index([movedToOrderItemId])
  @@map("shein_batch_items")
}
