model Expense {
  id                Int             @id @default(autoincrement())
  category          ExpenseCategory
  title             String
  amountBdt         Decimal         @db.Decimal(14, 4)
  date              DateTime
  paymentMethod     String?
  relatedPurchaseId Int?
  relatedOrderId    Int?
  relatedVariantId  Int?
  notes             String?
  isActive          Boolean         @default(true)
  purchase          Purchase?       @relation(fields: [relatedPurchaseId], references: [id], onDelete: SetNull)
  order             Order?          @relation(fields: [relatedOrderId], references: [id], onDelete: SetNull)
  variant           ProductVariant? @relation(fields: [relatedVariantId], references: [id], onDelete: SetNull)
  createdById       Int?
  updatedById       Int?
  createdBy         User?           @relation("ExpenseCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy         User?           @relation("ExpenseUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([category])
  @@index([date])
  @@index([category, date])
  @@index([relatedPurchaseId])
  @@index([relatedOrderId])
  @@index([relatedVariantId])
  @@index([createdById])
  @@index([updatedById])
  @@map("expenses")
}
