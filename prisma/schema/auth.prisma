model User {
  id               Int              @id @default(autoincrement())
  email            String           @unique
  passwordHash     String
  name             String?
  role             UserRole         @default(ADMIN)
  isActive         Boolean          @default(true)
  lastLoginAt      DateTime?
  createdProducts  Product[]        @relation("ProductCreatedBy")
  updatedProducts  Product[]        @relation("ProductUpdatedBy")
  createdVariants  ProductVariant[] @relation("ProductVariantCreatedBy")
  updatedVariants  ProductVariant[] @relation("ProductVariantUpdatedBy")
  createdSuppliers Supplier[]       @relation("SupplierCreatedBy")
  updatedSuppliers Supplier[]       @relation("SupplierUpdatedBy")
  createdPurchases Purchase[]       @relation("PurchaseCreatedBy")
  updatedPurchases Purchase[]       @relation("PurchaseUpdatedBy")
  createdOrders    Order[]          @relation("OrderCreatedBy")
  updatedOrders    Order[]          @relation("OrderUpdatedBy")
  createdExpenses  Expense[]        @relation("ExpenseCreatedBy")
  updatedExpenses  Expense[]        @relation("ExpenseUpdatedBy")
  createdMovements StockMovement[]  @relation("StockMovementCreatedBy")
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([isActive])
  @@index([role])
  @@map("users")
}
